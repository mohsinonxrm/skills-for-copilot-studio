# Copilot Studio Claude Code Project - Git Ignore

# Agents clones
src/
*.zip

# Agent tests
tests/test-results*
tests/settings.json
tests/agents.json
tests/.token_cache.json
tests/node_modules/
tests/package-lock.json

# Python cache
__pycache__/
*.pyc
