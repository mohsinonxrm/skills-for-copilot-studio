# Copilot Studio Plugin - Git Ignore

*.zip

# Agent tests (user-specific)
tests/test-results*
tests/settings.json
tests/agents.json
tests/.token_cache.json
tests/node_modules/
tests/package-lock.json

# Python cache (legacy)
__pycache__/
*.pyc
*.pyo

# Schema lookup build artifacts (only the bundled schema-lookup.js ships)
scripts/node_modules/
scripts/package-lock.json

# AI agent local settings (not part of the plugin)
.claude/

# VS Code settings (optional - remove if you want to share settings)
.vscode/
.github/copilot-instructions.md

# Agent tmp files (in any subfolder)
tmpclaude-*

# Environment files (if used in the future)
.env
.env.local
nul
